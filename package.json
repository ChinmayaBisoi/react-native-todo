    "moduleNameMapper": {
      "^@gluestack-ui/themed$": "<rootDir>/__mocks__/@gluestack-ui/themed.tsx",
      "^@gluestack-ui/config$": "<rootDir>/__mocks__/@gluestack-ui/config.ts"
    }
  },
  "dependencies": {
    "@gluestack-style/react": "^1.0.57",
    "@gluestack-ui/config": "^1.1.20",
    "@gluestack-ui/themed": "^1.1.73",
    "expo": "~54.0.0",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-svg": "^13.4.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.8.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "typescript": "~5.9.2"
  },
  "private": true
}
